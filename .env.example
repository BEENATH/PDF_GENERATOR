# Server configuration
PORT=3000
NODE_ENV=development

# API Key Authentication
# The API will validate this key in the Authorization header: Bearer <API_KEY>
API_KEY=pdf_secret_key_123456

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Puppeteer Options
# If deploying to a production server, you may need to specify the path to Chromium
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
